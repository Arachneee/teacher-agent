<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <property name="LOG_DIR" value="logs"/>
    <property name="LOG_FILE" value="teacher-agent"/>

    <!-- 콘솔 출력 -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- 일별 롤링 파일 출력 -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_DIR}/${LOG_FILE}.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <!-- 하루마다 롤링: 날짜가 바뀌면 새 파일로 교체 -->
            <fileNamePattern>${LOG_DIR}/${LOG_FILE}.%d{yyyy-MM-dd}.log</fileNamePattern>
            <!-- 보관 기간: 30일 -->
            <maxHistory>30</maxHistory>
            <!-- 전체 로그 디렉토리 최대 용량 -->
            <totalSizeCap>1GB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- 로컬/개발 환경: 콘솔만 출력 -->
    <springProfile name="!prod">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>
        <logger name="com.teacher.agent" level="DEBUG"/>
        <logger name="io.netty.resolver.dns.DnsServerAddressStreamProviders" level="OFF"/>
    </springProfile>

    <!-- 프로덕션 환경: 파일로 출력 -->
    <springProfile name="prod">
        <root level="INFO">
            <appender-ref ref="FILE"/>
        </root>
        <logger name="com.teacher.agent" level="INFO"/>
        <logger name="io.netty.resolver.dns.DnsServerAddressStreamProviders" level="OFF"/>
    </springProfile>

</configuration>
